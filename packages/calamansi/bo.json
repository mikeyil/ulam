  "about.feature_ai_body": "AI བེད་སྤྱོད་བྱས་ནས་ཁྱེད་ཀྱི་མཆན་ལྟར་ཐོར་བུ་གསར་འབྲི་བྱེད། Anthropic、OpenAI、ཡང་ན་Googleལས་ API ལྡེ་མིག་རང་ལ་གཟིགས་རོགས། ལྡེ་མིག་ཁྱེད་ཀྱི་བར་སྣང་ལ་མི་འགྲོ་ཞིང་ང་ཚོར་ནམ་ཡང་སྐྱེལ་མི་འབྱུང་། གཤམ་གྱི་",
  "about.feature_languages_label": "སྐད་ཡིག 50+",
  "about.feature_languages_body": "དཀར་ཆག་འདི་RTL རྒྱབ་རྟེན་ཡོད་པའི་ཡིག་གཞུང་ 50 ལྷག་ལ་ཐོབ་ཐུབ། ང་ལ་སྐད་ཡིག་དང་རིག་གཞུང་། སྐད་རིགས་རིག་པར་དགའ་ཞིང་འོད་སྣང་ཆེ། སྐད་ཡིག་འདི་ཐམས་ཅད་ཚུད་གཏོང་བ་ནི་རྩེད་མོའི་ལམ་ལྡེ་ཞིག་ལྟ་བུ་རེད། ཆ་རེ་ཚོད་ལྟ། ཆ་རེ་གྲོ་ལམ། ཆ་རེ་ཅུང་གཡེང་བར་གྱུར། བསྒྱུར་བཅོས་AI གིས་བྱས་པས། བསྒྱུར་ཐབས་ལ་ཡིད་ཆེས་མ་འཇོག་རོགས། བསྒྱུར་འཕྲད་ཀྱི་འདེམས་སྒྲུག་",
