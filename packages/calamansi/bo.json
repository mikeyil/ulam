  "settings.privacy_body_1": "ད་ལྟ་གཞི་གྲངས་ཐམས་ཅད་localStorage བེད་སྤྱོད་བྱས་ཁྱེད་ཀྱི་བར་སྣང་ལ་གནས་ཡོད། ང་ཚོར་ཡང་ན་གཞུང་ཁྱིམ་གང་ཡང་སྐྱེལ་མི་འབྱུང་། ཉར་བཞག་གི་གཞི་གྲངས་ལ་ཚུད་པ། བཀྲ་ཤིས་། སྐད་ཡིག། མེད་ལེན་ཆ་སྒྲིག། གསོན་འཚོལ་གཞི་བཀོད། AI ཞབས་འདེགས་ཤིང་བུ་གདམས་ཀ། API ལྡེ་མིག། གནས་རིམ། སྐར་མ། མཛོད་བཞག་ཚན་པ། སྦར་བཞག་ཚན་པ། ཐོར་བུ་ཉེ་ལས། སྒེར་གྱི་ཐོར་བུ། སྒེར་གྱི་གྲུབ་ཚང་བཀོལ་ཆ། དང་ཁྱེད་ཀྱིས་ཐོག་མར་བལྟས་པའི་ཐོར་བུ།",
  "settings.privacy_body_2": "API ལྡེ་མིག་ཁྱེད་ཀྱི་བར་སྣང་ལ་ཉར་བཞག་ཡིན་ཞིང་ཁྱེད་ཀྱིས་གཞི་བཀོད་བྱས་པའི་AI ཞབས་འདེགས་ལ་ཐད་ཀར་སྐྱེལ་བ་ཡིན། ང་ཚོས་ནམ་ཡང་མཐོང་ཡང་མེད་འཇལ་ཡང་མེད། སྐབས་གང་ཡང་གཤམ་གྱི་AI གཞི་བཀོད་ལས་ཕྱིར་བསུབ་ཐུབ། ཡང་ན་འདི་ཤོག་ངོས་ཀྱི་བར་སྣང་གཞི་གྲངས་གཙང་བྱས་ཀྱང་འགྲིག",
  "settings.privacy_body_translations": "UI བསྒྱུར་ཡིག་དང་གཞི་རྩའི་སྤྱི་ཚོགས་གྲུབ་ཚང་AI གིས་བསྒྱུར་བས་ནོར་འཁྲུལ་ཡོང་སྲིད། སྤྱོད་མཁན་གྱིས་བཀྲམ་པའི་གཞི་གྲངས། སྒེར་གྱི་ཐོར་བུ། ཡང་ན་སྒེར་གྱི་བཀོལ་ཆ་གང་ཡང་བསྒྱུར་ཆེད་སྐྱེལ་བར་མི་འགྱུར།",
